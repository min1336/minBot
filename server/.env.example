# === minBot Server Configuration ===

# Deepgram STT
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Groq LLM
GROQ_API_KEY=your_groq_api_key_here

# ElevenLabs TTS + Voice Clone
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_cloned_voice_id_here

# Voice Clone Provider: elevenlabs | xtts | cosyvoice
VOICE_CLONE_PROVIDER=elevenlabs

# XTTS v2 (self-hosted)
XTTS_SERVER_URL=http://localhost:8001

# CosyVoice 2 (self-hosted)
COSYVOICE_SERVER_URL=http://localhost:8002

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# JWT Auth
JWT_SECRET_KEY=change_this_to_a_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Personality
BOT_NAME=미니
DEFAULT_PERSONALITY=friendly
